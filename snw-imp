<html lang="zh-TW">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>花蓮縣各校網路改善清單</title>
<link href="https://fonts.googleapis.com/css2?family=Noto+Sans+TC:wght@300;400;500;700&family=DM+Sans:wght@300;400;500;600&display=swap" rel="stylesheet">
<style>
  :root {
    --bg: #0d0f14;
    --surface: #161920;
    --surface2: #1e2230;
    --border: rgba(255,255,255,0.07);
    --text: #eef0f5;
    --text-muted: #7a8099;
    --text-dim: #454c63;
    --c1: #4f9cf9;
    --c1-glow: rgba(79,156,249,0.25);
    --c1-bg: rgba(79,156,249,0.1);
    --c2: #2dd4a7;
    --c2-glow: rgba(45,212,167,0.25);
    --c2-bg: rgba(45,212,167,0.1);
    --c3: #f97b4f;
    --c3-glow: rgba(249,123,79,0.25);
    --c3-bg: rgba(249,123,79,0.1);
    --c4: #c084fc;
    --c4-glow: rgba(192,132,252,0.25);
    --c4-bg: rgba(192,132,252,0.1);
  }

  * { margin:0; padding:0; box-sizing:border-box; }

  body {
    font-family: 'Noto Sans TC', sans-serif;
    background: var(--bg);
    color: var(--text);
    min-height: 100vh;
    overflow-x: hidden;
  }

  /* Grid background */
  body::before {
    content: '';
    position: fixed;
    inset: 0;
    background-image:
      linear-gradient(rgba(255,255,255,0.025) 1px, transparent 1px),
      linear-gradient(90deg, rgba(255,255,255,0.025) 1px, transparent 1px);
    background-size: 48px 48px;
    pointer-events: none;
    z-index: 0;
  }

  .container { position: relative; z-index: 1; max-width: 1200px; margin: 0 auto; padding: 40px 24px 80px; }

  /* Header */
  .header { margin-bottom: 40px; }
  .header-eyebrow {
    font-family: 'DM Sans', sans-serif;
    font-size: 11px;
    font-weight: 500;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--text-muted);
    margin-bottom: 12px;
    display: flex;
    align-items: center;
    gap: 8px;
  }
  .header-eyebrow::before {
    content: '';
    display: inline-block;
    width: 20px;
    height: 1px;
    background: var(--text-muted);
  }
  .header h1 {
    font-size: 32px;
    font-weight: 700;
    letter-spacing: -0.02em;
    color: var(--text);
    margin-bottom: 8px;
  }
  .header p {
    font-size: 14px;
    color: var(--text-muted);
    font-weight: 300;
  }

  /* Category cards */
  .cat-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 12px;
    margin-bottom: 32px;
  }

  .cat-card {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 14px;
    padding: 20px;
    cursor: pointer;
    transition: all 0.25s cubic-bezier(0.4,0,0.2,1);
    position: relative;
    overflow: hidden;
  }
  .cat-card::after {
    content: '';
    position: absolute;
    inset: 0;
    border-radius: 14px;
    opacity: 0;
    transition: opacity 0.25s;
  }
  .cat-card:hover { transform: translateY(-2px); }
  .cat-card.active { border-color: transparent; }

  .cat-card[data-ci="0"]::after { box-shadow: inset 0 0 0 2px var(--c1); }
  .cat-card[data-ci="1"]::after { box-shadow: inset 0 0 0 2px var(--c2); }
  .cat-card[data-ci="2"]::after { box-shadow: inset 0 0 0 2px var(--c3); }
  .cat-card[data-ci="3"]::after { box-shadow: inset 0 0 0 2px var(--c4); }

  .cat-card.active[data-ci="0"] { background: var(--c1-bg); }
  .cat-card.active[data-ci="1"] { background: var(--c2-bg); }
  .cat-card.active[data-ci="2"] { background: var(--c3-bg); }
  .cat-card.active[data-ci="3"] { background: var(--c4-bg); }
  .cat-card.active::after { opacity: 1; }

  .cat-icon {
    width: 36px; height: 36px;
    border-radius: 10px;
    display: flex; align-items: center; justify-content: center;
    margin-bottom: 14px;
    font-size: 16px;
  }
  .cat-card[data-ci="0"] .cat-icon { background: var(--c1-bg); }
  .cat-card[data-ci="1"] .cat-icon { background: var(--c2-bg); }
  .cat-card[data-ci="2"] .cat-icon { background: var(--c3-bg); }
  .cat-card[data-ci="3"] .cat-icon { background: var(--c4-bg); }

  .cat-count {
    font-family: 'DM Sans', sans-serif;
    font-size: 36px;
    font-weight: 600;
    line-height: 1;
    margin-bottom: 4px;
    letter-spacing: -0.03em;
  }
  .cat-card[data-ci="0"] .cat-count { color: var(--c1); }
  .cat-card[data-ci="1"] .cat-count { color: var(--c2); }
  .cat-card[data-ci="2"] .cat-count { color: var(--c3); }
  .cat-card[data-ci="3"] .cat-count { color: var(--c4); }

  .cat-label { font-size: 13px; font-weight: 500; color: var(--text); margin-bottom: 2px; }
  .cat-sub { font-size: 11px; color: var(--text-muted); }

  /* Main content layout */
  .content-grid {
    display: grid;
    grid-template-columns: 1fr 340px;
    gap: 16px;
    align-items: start;
  }

  /* Bar chart */
  .chart-panel {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 16px;
    padding: 24px;
  }

  .panel-header {
    display: flex;
    align-items: baseline;
    gap: 10px;
    margin-bottom: 20px;
  }
  .panel-title {
    font-size: 14px;
    font-weight: 500;
    color: var(--text);
  }
  .panel-badge {
    font-family: 'DM Sans', sans-serif;
    font-size: 11px;
    font-weight: 500;
    padding: 3px 8px;
    border-radius: 20px;
    letter-spacing: 0.03em;
  }
  #panelBadge0 { background: var(--c1-bg); color: var(--c1); }
  #panelBadge1 { background: var(--c2-bg); color: var(--c2); }
  #panelBadge2 { background: var(--c3-bg); color: var(--c3); }
  #panelBadge3 { background: var(--c4-bg); color: var(--c4); }

  .bar-scroll { max-height: 520px; overflow-y: auto; padding-right: 4px; }
  .bar-scroll::-webkit-scrollbar { width: 3px; }
  .bar-scroll::-webkit-scrollbar-track { background: transparent; }
  .bar-scroll::-webkit-scrollbar-thumb { background: var(--border); border-radius: 4px; }

  .bar-row {
    display: flex;
    align-items: center;
    gap: 10px;
    margin-bottom: 8px;
    cursor: pointer;
    padding: 4px 6px;
    border-radius: 6px;
    transition: background 0.15s;
  }
  .bar-row:hover { background: rgba(255,255,255,0.04); }

  .bar-name {
    width: 88px;
    min-width: 88px;
    font-size: 12px;
    color: var(--text-muted);
    text-align: right;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    transition: color 0.15s;
  }
  .bar-row:hover .bar-name { color: var(--text); }

  .bar-track {
    flex: 1;
    height: 28px;
    background: rgba(255,255,255,0.04);
    border-radius: 6px;
    position: relative;
    overflow: hidden;
  }

  .bar-fill {
    height: 100%;
    border-radius: 6px;
    display: flex;
    align-items: center;
    padding: 0 8px;
    transition: width 0.5s cubic-bezier(0.4,0,0.2,1);
    min-width: 36px;
  }
  .bar-val {
    font-family: 'DM Sans', sans-serif;
    font-size: 11px;
    font-weight: 500;
    white-space: nowrap;
  }

  .bar-town {
    width: 52px;
    min-width: 52px;
    font-size: 10px;
    color: var(--text-dim);
    text-align: right;
  }

  /* Right panel */
  .right-panel {
    display: flex;
    flex-direction: column;
    gap: 14px;
  }

  /* Donut chart panel */
  .donut-panel {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 16px;
    padding: 20px;
  }

  .donut-wrap {
    display: flex;
    align-items: center;
    gap: 16px;
    margin-top: 16px;
  }

  canvas#donut { flex-shrink: 0; }

  .donut-legend { flex: 1; }
  .donut-item {
    display: flex;
    align-items: center;
    gap: 8px;
    margin-bottom: 10px;
    cursor: pointer;
    padding: 5px 8px;
    border-radius: 8px;
    transition: background 0.15s;
  }
  .donut-item:hover { background: rgba(255,255,255,0.04); }
  .donut-item.active { background: rgba(255,255,255,0.06); }
  .donut-dot { width: 8px; height: 8px; border-radius: 50%; flex-shrink: 0; }
  .donut-name { font-size: 12px; color: var(--text-muted); flex: 1; }
  .donut-n {
    font-family: 'DM Sans', sans-serif;
    font-size: 13px;
    font-weight: 600;
  }

  /* School tag panel */
  .tags-panel {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 16px;
    padding: 20px;
    max-height: 320px;
    overflow-y: auto;
  }
  .tags-panel::-webkit-scrollbar { width: 3px; }
  .tags-panel::-webkit-scrollbar-track { background: transparent; }
  .tags-panel::-webkit-scrollbar-thumb { background: var(--border); border-radius: 4px; }

  .tags-title {
    font-size: 13px;
    font-weight: 500;
    color: var(--text);
    margin-bottom: 14px;
    display: flex;
    align-items: center;
    gap: 8px;
  }
  .tags-title-count {
    font-family: 'DM Sans', sans-serif;
    font-size: 11px;
    padding: 2px 7px;
    border-radius: 20px;
  }

  .tag-grid { display: flex; flex-wrap: wrap; gap: 6px; }
  .school-tag {
    font-size: 11px;
    padding: 4px 10px;
    border-radius: 20px;
    cursor: default;
    transition: transform 0.15s;
    border: 1px solid transparent;
  }
  .school-tag:hover { transform: scale(1.04); }

  /* Stat cards row */
  .stat-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 10px;
    margin-top: 0;
  }
  .stat-card {
    background: var(--surface2);
    border-radius: 12px;
    padding: 14px;
  }
  .stat-label { font-size: 10px; color: var(--text-dim); text-transform: uppercase; letter-spacing: 0.08em; margin-bottom: 6px; }
  .stat-val {
    font-family: 'DM Sans', sans-serif;
    font-size: 22px;
    font-weight: 600;
    color: var(--text);
  }
  .stat-unit { font-size: 11px; color: var(--text-muted); font-weight: 400; margin-left: 2px; }

  /* Footer */
  .footer {
    margin-top: 40px;
    padding-top: 20px;
    border-top: 1px solid var(--border);
    display: flex;
    align-items: center;
    justify-content: space-between;
    font-size: 11px;
    color: var(--text-dim);
  }

  /* Transition */
  .fade-in { animation: fadeIn 0.35s ease; }
  @keyframes fadeIn { from { opacity:0; transform: translateY(6px); } to { opacity:1; transform:translateY(0); } }

  @media (max-width: 900px) {
    .cat-grid { grid-template-columns: repeat(2,1fr); }
    .content-grid { grid-template-columns: 1fr; }
    .header h1 { font-size: 22px; }
  }
</style>
</head>
