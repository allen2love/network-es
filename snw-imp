let selCat = 0;
const counts = [0,1,2,3].map(ci => schools.filter(s=>s.c[ci]===1).length);
document.getElementById('totalCount').textContent = schools.length;

function totalStudents(ci) {
  return schools.filter(s=>s.c[ci]===1).reduce((a,s)=>a+s.s,0);
}
function avgStudents(ci) {
  const list = schools.filter(s=>s.c[ci]===1);
  return list.length ? Math.round(list.reduce((a,s)=>a+s.s,0)/list.length) : 0;
}

function select(ci) {
  selCat = ci;
  document.querySelectorAll('.cat-card').forEach(el => el.classList.remove('active'));
  document.querySelector(`.cat-card[data-ci="${ci}"]`).classList.add('active');
  [0,1,2,3].forEach(i => {
    const b = document.getElementById('panelBadge'+i);
    b.style.display = i===ci ? 'inline-block' : 'none';
  });

  const titles = ['網路改善（教育處補助）','局部網路改善（學校自費）','建議改善名單','網路機房整線（學校自費）'];
  document.getElementById('panelTitle').textContent = titles[ci];

  renderBars(ci);
  renderTags(ci);
  renderStats(ci);
  drawDonut(ci);
}

function renderBars(ci) {
  const list = schools.filter(s=>s.c[ci]===1).sort((a,b)=>b.s-a.s);
  const max = list[0]?.s || 1;
  const color = COLORS[ci];
  const bg = COLORS_BG[ci];
  const barList = document.getElementById('barList');
  barList.innerHTML = '';

  list.forEach((s,i) => {
    const pct = Math.round((s.s/max)*100);
    const row = document.createElement('div');
    row.className = 'bar-row';
    row.style.animationDelay = (i*0.02)+'s';
    row.innerHTML = `
      <div class="bar-name" title="${s.t} ${s.name}">${s.name}</div>
      <div class="bar-track">
        <div class="bar-fill" style="width:${pct}%;background:${bg};border:1px solid ${COLORS_BORDER[ci]};">
          <span class="bar-val" style="color:${color};">${s.s}</span>
        </div>
      </div>
      <div class="bar-town">${s.t}</div>`;
    barList.appendChild(row);
    setTimeout(() => {
      row.querySelector('.bar-fill').style.width = pct+'%';
    }, 30 + i*15);
  });

  document.getElementById('panelBadge'+ci).textContent = counts[ci]+' 所學校';
}

function renderTags(ci) {
  const list = schools.filter(s=>s.c[ci]===1).sort((a,b)=>b.s-a.s);
  const color = COLORS[ci];
  const bg = COLORS_BG[ci];
  const border = COLORS_BORDER[ci];
  const tc = document.getElementById('tagsCount');
  tc.textContent = list.length+' 所';
  tc.style.background = bg;
  tc.style.color = color;

  document.getElementById('tagGrid').innerHTML = list.map(s =>
    `<span class="school-tag" style="background:${bg};border-color:${border};color:${color};" title="${s.s} 人">${s.name}</span>`
  ).join('');
}

function renderStats(ci) {
  const sr = document.getElementById('statRow');
  const color = COLORS[ci];
  const total = totalStudents(ci);
  const avg = avgStudents(ci);
  sr.innerHTML = `
    <div class="stat-card">
      <div class="stat-label">涵蓋學生人數</div>
      <div class="stat-val" style="color:${color}">${total.toLocaleString()}<span class="stat-unit">人</span></div>
    </div>
    <div class="stat-card">
      <div class="stat-label">平均每校人數</div>
      <div class="stat-val" style="color:${color}">${avg}<span class="stat-unit">人</span></div>
    </div>`;
}

function drawDonut(activeCi) {
  const canvas = document.getElementById('donut');
  const ctx = canvas.getContext('2d');
  const W = 100, H = 100;
  const cx = W/2, cy = H/2, r = 38, inner = 24;
  ctx.clearRect(0,0,W,H);

  const total = counts.reduce((a,b)=>a+b,0);
  let start = -Math.PI/2;

  counts.forEach((v, i) => {
    const sweep = (v/total) * Math.PI * 2;
    ctx.beginPath();
    ctx.moveTo(cx,cy);
    ctx.arc(cx,cy, i===activeCi ? r+4 : r, start, start+sweep);
    ctx.closePath();
    ctx.fillStyle = i===activeCi ? COLORS[i] : COLORS_BG[i];
    ctx.fill();

    if(i===activeCi) {
      ctx.beginPath();
      ctx.arc(cx,cy,r+4,start,start+sweep);
      ctx.strokeStyle = COLORS[i];
      ctx.lineWidth = 1.5;
      ctx.stroke();
    }
    start += sweep;
  });

  ctx.beginPath();
  ctx.arc(cx,cy,inner,0,Math.PI*2);
  ctx.fillStyle = '#161920';
  ctx.fill();

  ctx.fillStyle = COLORS[activeCi];
  ctx.font = 'bold 14px DM Sans, sans-serif';
  ctx.textAlign = 'center';
  ctx.textBaseline = 'middle';
  ctx.fillText(counts[activeCi], cx, cy-6);
  ctx.fillStyle = '#7a8099';
  ctx.font = '8px Noto Sans TC, sans-serif';
  ctx.fillText('所', cx, cy+7);

  const legend = document.getElementById('donutLegend');
  legend.innerHTML = counts.map((v,i) => `
    <div class="donut-item ${i===activeCi?'active':''}" onclick="select(${i})">
      <span class="donut-dot" style="background:${COLORS[i]};${i!==activeCi?'opacity:0.4':''}"></span>
      <span class="donut-name" style="${i===activeCi?'color:var(--text)':''}">${CATS[i]}</span>
      <span class="donut-n" style="color:${COLORS[i]}">${v}</span>
    </div>`).join('');
}

